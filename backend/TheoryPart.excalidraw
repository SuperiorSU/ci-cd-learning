    {
      "id": "t15VEIU3H-0UXIgdA-dJQ",
      "type": "text",
      "x": 141.7838612070774,
      "y": 1340.045347461457,
      "width": 983.5863037109375,
      "height": 809.0877452547876,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1A",
      "roundness": null,
      "seed": 370849591,
      "version": 1587,
      "versionNonce": 1202148166,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777791502123,
      "link": null,
      "locked": false,
      "text": "We use GitHub Actions Here, and the steps are listed below\n\n -- Create the project\n -- Initiate the repo\n -- Go to Actions tab\n -- Select Continuous Integration Option\n -- Select/Search a specific tech stack template\n -- On configuring, we get a .yaml file\n\n.yml or .yaml file consists of syntax that includes necessary \ninformation to define the workflows. These consists of name of\nworkflow, jobs, steps, event that triggers the workflows etc. The\njobs can be nested with multiple steps for each of them. Further\nthe steps have their name and the command to be run\n\nThe command in the steps may run on the servers, be it ubuntu, microsoft\n(in the GitHub Servers, if GitHub Actions is considered here) or we can use \nself hosted server-- where we can use EC2 or any other self hosted server\n\nThe jobs run on individual VMs, parallely which is configured automatically by \nGitHub itself. \n\nWe have a \"matrix\" option inside .yml that is a matrix of options. The matrix \nallows us to test a OS specific application. These options are nothing but \nservers with different configurations",
      "fontSize": 25.8908078481532,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We use GitHub Actions Here, and the steps are listed below\n\n -- Create the project\n -- Initiate the repo\n -- Go to Actions tab\n -- Select Continuous Integration Option\n -- Select/Search a specific tech stack template\n -- On configuring, we get a .yaml file\n\n.yml or .yaml file consists of syntax that includes necessary \ninformation to define the workflows. These consists of name of\nworkflow, jobs, steps, event that triggers the workflows etc. The\njobs can be nested with multiple steps for each of them. Further\nthe steps have their name and the command to be run\n\nThe command in the steps may run on the servers, be it ubuntu, microsoft\n(in the GitHub Servers, if GitHub Actions is considered here) or we can use \nself hosted server-- where we can use EC2 or any other self hosted server\n\nThe jobs run on individual VMs, parallely which is configured automatically by \nGitHub itself. \n\nWe have a \"matrix\" option inside .yml that is a matrix of options. The matrix \nallows us to test a OS specific application. These options are nothing but \nservers with different configurations",
      "autoResize": true,
      "lineHeight": 1.25
    },
